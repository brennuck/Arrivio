{
  "manifest_version": 3,
  "name": "Arrivio",
  "version": "1.0.0",
  "description": "See drive times to your important places while browsing real estate listings.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.mapbox.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.zillow.com/*",
        "*://*.realtor.com/*",
        "*://*.apartments.com/*",
        "*://*.trulia.com/*",
        "*://*.redfin.com/*",
        "*://*.valleymls.com/*",
        "*://*.liveinalabama.com/*",
        "*://*.alaskarealestate.com/*",
        "*://*.armls.com/*",
        "*://*.arkansasstatemls.com/*",
        "*://*.crmls.org/*",
        "*://*.recolorado.com/*",
        "*://*.smartmls.com/*",
        "*://*.brightmls.com/*",
        "*://*.stellarmls.com/*",
        "*://*.georgiamls.com/*",
        "*://*.hawaiiinformation.com/*",
        "*://*.mredllc.com/*",
        "*://*.reindiana.com/*",
        "*://*.mainelistings.com/*",
        "*://*.mlspin.com/*",
        "*://*.realcomp.com/*",
        "*://*.northstarmls.com/*",
        "*://*.406mls.com/*",
        "*://*.nnrmls.com/*",
        "*://*.primemls.com/*",
        "*://*.newjerseymls.com/*",
        "*://*.mystatemls.com/*",
        "*://*.streeteasy.com/*",
        "*://*.northcarolinastatemls.com/*",
        "*://*.okcmar.org/*",
        "*://*.rmlscentral.com/*",
        "*://*.riliving.com/*",
        "*://*.realtracs.com/*",
        "*://*.har.com/*",
        "*://*.utahrealestate.com/*",
        "*://*.nwmls.com/*",
        "*://*.bridgemls.com/*"
      ],
      "js": ["src/content/index.tsx"]
    }
  ],
  "options_page": "src/options/index.html",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "src/assets/icons/icon16.png",
      "48": "src/assets/icons/icon48.png",
      "128": "src/assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "src/assets/icons/icon16.png",
    "48": "src/assets/icons/icon48.png",
    "128": "src/assets/icons/icon128.png"
  }
}
